// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(ADMIN)
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

enum UserRole {
  ADMIN
  MANAGER
}

model Category {
  id        String   @id @default(ulid())
  name      String
  slug      String   @unique()
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@map("categories")
}

model Product {
  id               String   @id @default(ulid())
  categoryId       String
  name             String
  description      String?
  price            Float
  stock            Int
  minimumThreshold Int
  isDeleted        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id])

  @@map("products")
}

model Order {
  id           String      @id @default(ulid())
  customerName String
  totalPrice   Float
  status       OrderStatus @default(PENDING)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  orderItems OrderProductJunction[]

  @@map("orders")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

model OrderProductJunction {
  id        String @id @default(ulid())
  orderId   String
  productId String
  quantity  Int

  order Order @relation(fields: [orderId], references: [id])

  @@unique([orderId, productId])
  @@map("order_product_junction")
}

model Activity {
  id        String         @id @default(uuid())
  entity    ActivityEntity
  message   String
  createdAt DateTime       @default(now())

  @@map("activities")
}

enum ActivityEntity {
  PRODUCT
  ORDER
}

enum ActivityAction {
  CREATED
  UPDATED
  STATUS_CHANGED
}
